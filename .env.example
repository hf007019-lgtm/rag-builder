# PostgreSQL
POSTGRES_USER=rag_admin
POSTGRES_PASSWORD=rag_secure
POSTGRES_DB=rag_db
DATABASE_URL=postgresql+psycopg2://rag_admin:rag_secure@127.0.0.1:15432/rag_db

# MinIO
MINIO_ENDPOINT=127.0.0.1:19002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=rag-docs

# Redis / Celery
REDIS_URL=redis://127.0.0.1:16379/0

# Elasticsearch
ES_URL=http://127.0.0.1:9200
ES_INDEX_NAME=rag_chunks
ES_VECTOR_DIMS=1536

# DashScope OpenAI-compatible API
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_dashscope_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key
EMBEDDING_MODEL_NAME=text-embedding-v2
CHAT_MODEL_NAME=qwen-plus

# Optional rerank
RERANK_ENABLED=false
RERANK_PROVIDER=dashscope
RERANK_MODEL_NAME=qwen3-rerank
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_TOP_N=30
RERANK_TOP_K=5
RERANK_TIMEOUT_SECONDS=20
RERANK_APPLY_TO_ASK=false
